  "image": "wcs-logo.png",
  "searchTags": [],
  "dist": {
    "basePath": "dist/bundle/noi-a22-emission-index",
    "files": [
      "noi-a22-emission-index.js",
      "data_a22.json",
      "i18n_en.json",
      "i18n_it.json"
    ],
    "scripts": [
      {
        "file": "noi-a22-emission-index.js",
        "parameter": "type='module'"
      }
    ]
  },
  "configuration": {
    "tagName": "noi-a22-emission-index",
    "options": [
      {
        "key": "layout",
        "type": "select",
        "label": "Layout appearance",
        "required": false,
        "options": {
          "values": [
            "desktop",
            "tablet",
            "mobile",
            "auto"
          ],
          "default": "auto"
        }
      },
      {
        "key": "language",
        "type": "select",
        "label": "Two letter key for the language to be used, if omitted the widget will use the browser language. Fallback is `en`",
        "required": false,
        "options": {
          "values": [
            "en",
            "it"
          ],
          "default": "en"
        }
      }
    ]
  }
}
